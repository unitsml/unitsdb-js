{
  "name": "@unitsml/unitsdb",
  "version": "3.0.0",
  "private": false,
  "description": "JavaScript release of unitsdb-ruby. Opal-compiled with optional shared runtime from @lutaml/opal-runtime. v3 replaces the JSON+façade approach with a real Ruby class hierarchy.",
  "main": "./dist/unitsdb-no-opal.js",
  "module": "./dist/unitsdb-no-opal.js",
  "browser": "./dist/unitsdb.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/unitsdb.js",
      "import": "./dist/unitsdb-no-opal.js",
      "require": "./dist/unitsdb-no-opal.js",
      "default": "./dist/unitsdb-no-opal.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node scripts/test.js"
  },
  "keywords": [
    "units",
    "unitsml",
    "unitsdb",
    "si",
    "metrology",
    "opal",
    "ruby"
  ],
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/unitsml/unitsdb-js"
  },
  "homepage": "https://github.com/unitsml/unitsdb-js#readme",
  "bugs": {
    "url": "https://github.com/unitsml/unitsdb-js/issues"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@lutaml/opal-runtime": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@lutaml/opal-runtime": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}